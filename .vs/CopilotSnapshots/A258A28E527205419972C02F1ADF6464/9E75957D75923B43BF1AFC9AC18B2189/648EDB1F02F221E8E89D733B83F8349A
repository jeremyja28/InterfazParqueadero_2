        // ═══════════════════════════════════════════════════════════
        // COBRO AUTOMÁTICO (disparado por escáner o botón manual)
        // 1) Muestra factura → 2) Espera confirmación → 3) Cobra, imprime, abre barrera
        // ═══════════════════════════════════════════════════════════
        private void EjecutarCobroAuto(TicketVisitante ticket)
        {
            // 1. Pre-calcular tarifa SIN modificar el ticket todavía
            var fechaSalida = DateTime.Now;
            var permanencia = fechaSalida - ticket.FechaEntrada;
            decimal horas = (decimal)Math.Ceiling(permanencia.TotalHours);
            if (horas < 1) horas = 1;
            decimal total = horas * TARIFA_HORA;

            // 2. Mostrar factura y esperar confirmación del operador
            if (!MostrarConfirmarPago(this, ticket, permanencia, horas, total))
            {
                // Cancelado: ticket sigue activo, restaurar combo y botón
                ActualizarComboTickets();
                return;
            }

            // 3. Confirmar: marcar como pagado
            ticket.FechaSalida = fechaSalida;
            ticket.TotalPagar = total;
            ticket.Activo = false;
            GuardarTicketsEnArchivo();
            CodigoTicket = ticket.Codigo;
            PlacaIngresada = ticket.Placa;
            UltimaAccion = "salida";
            _ticketSalida = null;
            ActualizarComboTickets();
            btnCobrarAbrir.Enabled = false;

            // 4. Mostrar resumen en pantalla
            lblResumenCobro.Text =
                $"╔═════════  COBRO CONFIRMADO  ═════════╗\n\n" +
                $"  📋  Ticket:       {ticket.Codigo}\n" +
                $"  🚗  Placa:         {ticket.Placa}\n\n" +
                $"  📅  Entrada:      {ticket.FechaEntrada:dd/MM/yyyy HH:mm:ss}\n" +
                $"  📅  Salida:        {ticket.FechaSalida:dd/MM/yyyy HH:mm:ss}\n\n" +
                $"  ⏱  Permanencia: {(int)permanencia.TotalHours}h {permanencia.Minutes}m {permanencia.Seconds}s\n" +
                $"  💵  Tarifa:         ${TARIFA_HORA}/hora  ×  {horas} hora(s)\n\n" +
                $"╚══════════════════════════════════╗\n" +
                $"   💰  TOTAL COBRADO:  ${ticket.TotalPagar:F2}\n" +
                $"╘══════════════════════════════════╝";

            // 5. Imprimir factura de salida
            ImprimirFacturaSalida(ticket);

            // 6. Registrar salida de aforo directamente (carro o moto según ticket)
            CapacidadService.RegistrarSalidaVisitante(ticket.EsMoto);

            // Registrar en bitácora global de auditoría
            AuditoriaService.Registrar("SALIÓ", "VISITANTE", "", $"Visitante ({ticket.Codigo})", ticket.Placa);

            // 7. Notificar dashboard y popup cobro exitoso
            OnVisitanteSalio?.Invoke(ticket.Placa, ticket.Codigo, ticket.TotalPagar);
            MostrarPopupCobroExitoso(this, ticket);

            // 7. Abrir barrera
            OnAbrirBarrera?.Invoke();

            lblResumenCobro.Text = "Escanee o seleccione un ticket activo\npara ver el resumen de cobro.";
        }

        // ═══════════════════════════════════════════════════════════
        // IMPRIMIR FACTURA DE SALIDA (mini comprobante de cobro)
        // ═══════════════════════════════════════════════════════════
        private void ImprimirFacturaSalida(TicketVisitante ticket)
        {
            try
            {
                var perm = ticket.FechaSalida!.Value - ticket.FechaEntrada;
                decimal horasCobradas = (decimal)Math.Ceiling(perm.TotalHours);
                if (horasCobradas < 1) horasCobradas = 1;

                byte[] data = new EscPosBuilder()
                    .Init()
                    .Left()
                    .TextLine("- Ticket perdido: $10.00")
                    .TextLine("- Cancelar antes de salir")
                    .Separator(32, '-')
                    .Center()
                    .Bold(true).DoubleHeight(true).TextLine("Parqueadero").TextLine("PUCESA").DoubleHeight(false).Bold(false)
                    .TextLine("Av. Los Chasquis s/n, Ambato")
                    .Separator(32, '-')
                    .Left()
                    .TextLine($"Comprobante: {ticket.Codigo}")
                    .TextLine("Cliente    : Visitante")
                    .Separator(32, '-')
                    .TextLine($"Hora de llegada:")
                    .TextLine($"  {ticket.FechaEntrada:dd/MM/yyyy  HH:mm:ss}")
                    .TextLine($"Hora de salida:")
                    .TextLine($"  {ticket.FechaSalida:dd/MM/yyyy  HH:mm:ss}")
                    .TextLine($"Placa      : {ticket.Placa}")
                    .TextLine($"Permanencia: {(int)perm.TotalHours}h {perm.Minutes}m {perm.Seconds}s")
                    .TextLine($"Horas cobradas: {horasCobradas}")
                    .TextLine($"Tarifa     : ${TARIFA_HORA} / hora")
                    .Separator(32, '=')
                    .Center()
                    .Bold(true)
                    .TextLine("Total a pagar:")
                    .DoubleHeight(true)
                    .TextLine($"  ${ticket.TotalPagar:F2}")
                    .DoubleHeight(false).Bold(false)
                    .Feed(4)
                    .FullCut()
                    .Build();

                RawPrinterHelper.SendBytesToPrinter(nombreImpresora, data);
            }
            catch (Exception ex)
            {
                MessageBox.Show(
                    $"No se pudo imprimir la factura de salida.\n\n{ex.Message}",
                    "Error de Impresión",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Warning);
            }
        }

