        /// <summary>
        /// Arma el ticket con EscPosBuilder y lo envía a la impresora usando RawPrinterHelper.
        /// Si la impresora no responde, muestra un MessageBox sin bloquear la aplicación.
        /// </summary>
        private void ImprimirTicketReal(TicketVisitante ticket)
        {
            try
            {
                byte[] data = new EscPosBuilder()
                    .Init()
                    .Left()
                    .TextLine("- Ticket perdido: $10.00")
                    .TextLine("- Cancelar antes de salir")
                    .Separator(32, '-')
                    .Center()
                    .Bold(true).DoubleHeight(true).TextLine("Parqueadero").TextLine("PUCESA").DoubleHeight(false).Bold(false)
                    .TextLine($"{ticket.FechaEntrada:dd/MM/yyyy}  {ticket.FechaEntrada:HH:mm:ss}")
                    .Separator(32, '-')
                    .Left()
                    .TextLine($"Codigo : {ticket.Codigo}")
                    .TextLine($"Placa  : {ticket.Placa}")
                    .TextLine($"Tarifa : ${TARIFA_HORA} / hora")
                    .Separator(32, '-')
                    .Center()
                    .Barcode128(ticket.Codigo)
                    .Feed(2)
                    .FullCut()
                    .Build();

                RawPrinterHelper.SendBytesToPrinter(nombreImpresora, data);
            }
            catch (Exception ex)
            {
                MessageBox.Show(
                    $"No se pudo imprimir el ticket.\n\n{ex.Message}",
                    "Error de Impresión",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Warning);
            }
        }

        // ═══════════════════════════════════════════════════════════
        // ESCÁNER USB — Captura global por KeyPreview
        // ═══════════════════════════════════════════════════════════
        /// <summary>
        /// Captura todas las pulsaciones del formulario (KeyPreview = true).
        /// Lógica de tiempo: si la diferencia entre teclas es menor a 50 ms se trata
        /// de una ráfaga del escáner; si es mayor, el operador está escribiendo y
        /// el evento se deja pasar al control con foco.
        /// Cuando llega un Enter precedido de una ráfaga rápida se procesa el código.
        /// </summary>
        /// <summary>
        /// Recorre la cadena de ContainerControl para encontrar el control hoja
        /// que realmente tiene el foco de entrada (puede estar profundamente anidado).
        /// </summary>
        private static Control? GetDeepFocused(ContainerControl root)
        {
            Control? active = root.ActiveControl;
            if (active is ContainerControl cc && cc.ActiveControl != null)
                return GetDeepFocused(cc);
            return active;
        }

        protected override void OnKeyPress(KeyPressEventArgs e)
        {
            base.OnKeyPress(e);

            // Solo bloquear captura cuando el foco está en el TextBox de la placa (operador escribiendo).
            // El ComboBox de tickets NO bloquea: el escáner siempre debe procesarse aunque el combo tenga foco.
            var focused = GetDeepFocused(this);
            if (focused is TextBox)
                return;

            var now = DateTime.Now;
            var elapsed = (now - _lastKeyTime).TotalMilliseconds;
            _lastKeyTime = now;

            if (e.KeyChar == '\r')   // Enter = terminador del escáner
            {
                string codigo = _scanBuffer.ToString().Trim();
                _scanBuffer.Clear();

                // Procesar si el buffer fue llenado por una ráfaga rápida del escáner
                // y el Enter llegó poco después (tolerancia 300 ms, algunos scanners pausan antes del Enter).
                if (!string.IsNullOrEmpty(codigo) && _bufferBuiltByScanner && elapsed < 300.0)
                {
                    _bufferBuiltByScanner = false;
                    ProcesarCodigoEscaneado(codigo);
                    e.Handled = true;
                }
                _bufferBuiltByScanner = false;
            }
            else if (e.KeyChar >= 32)   // Carácter imprimible
            {
                if (_scanBuffer.Length > 0 && elapsed < SCANNER_INTER_KEY_MS)
                {
                    // Chars llegando en ráfaga rápida → confirmar origen en escáner
                    _bufferBuiltByScanner = true;
                }
                else if (_scanBuffer.Length > 0 && elapsed >= SCANNER_INTER_KEY_MS)
                {
                    // Pausa larga detectada: el operador tecleó manualmente; descartar buffer
                    _scanBuffer.Clear();
                    _bufferBuiltByScanner = false;
                }
                // Si buffer estaba vacío: primer char, fuente aún desconocida (no tocar _bufferBuiltByScanner)

                _scanBuffer.Append(e.KeyChar);
                e.Handled = true;   // Suprimir para que no llegue a controles de fondo
            }
        }

        /// <summary>
        /// Localiza el código escaneado entre los tickets activos, lo selecciona
        /// automáticamente en el ComboBox y despliega el resumen de cobro.
        /// El operador solo tiene que hacer clic en "Cobrar y Abrir Barrera".
        /// </summary>
        private void ProcesarCodigoEscaneado(string codigo)
        {
            var activos = TicketsActivos.Where(t => t.Activo).ToList();
            var ticket = activos.FirstOrDefault(
                t => t.Codigo.Equals(codigo, StringComparison.OrdinalIgnoreCase));

            if (ticket == null)
            {
                MessageBox.Show(
                    $"No se encontró un ticket activo con el código \u201c{codigo}\u201d.\n" +
                    $"Verifique que el ticket sea válido y esté activo.",
                    "Ticket No Encontrado",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Warning);
                return;
            }

            // Seleccionar en el combo para que el operador vea cuál se procesó
            int idx = activos.IndexOf(ticket);
            if (idx >= 0 && idx < cmbTicketsActivos.Items.Count)
                cmbTicketsActivos.SelectedIndex = idx;

            // Auto-cobro: sin necesidad de pulsar ningún botón
            EjecutarCobroAuto(ticket);
        }

