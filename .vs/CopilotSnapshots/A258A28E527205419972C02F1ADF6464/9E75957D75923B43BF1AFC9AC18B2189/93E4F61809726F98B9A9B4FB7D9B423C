        };

        // -- Helper: RadioButton estilo toggle ------------------------------------
        private RadioButton CrearOpcionTipo(string texto, Color acento, bool seleccionada)
        {
            var rd = new RadioButton
            {
                Text       = texto,
                Font       = new Font("Segoe UI", 11.5f, FontStyle.Bold),
                ForeColor  = acento,
                Appearance = Appearance.Button,
                FlatStyle  = FlatStyle.Flat,
                TextAlign  = ContentAlignment.MiddleLeft,
                Padding    = new Padding(14, 0, 0, 0),
                Size       = new Size(420, 44),
                Checked    = seleccionada,
                Cursor     = Cursors.Hand,
                BackColor  = seleccionada ? Color.FromArgb(235, 244, 255) : C_Blanco
            };
            rd.FlatAppearance.BorderColor        = acento;
            rd.FlatAppearance.BorderSize         = 2;
            rd.FlatAppearance.CheckedBackColor   = Color.FromArgb(235, 244, 255);
            rd.FlatAppearance.MouseOverBackColor = Color.FromArgb(248, 251, 255);
            // Actualizar BackColor también al cambiar estado
            rd.CheckedChanged += (s, e) =>
                rd.BackColor = rd.Checked ? Color.FromArgb(235, 244, 255) : C_Blanco;
            return rd;
        }

        // -- Evento: cambio de tipo de apertura -----------------------------------
        private void TipoChanged(object? sender, EventArgs e)
        {
            bool esPaso = rdPasoRapido.Checked;
            panelDetalles.Visible = !esPaso;
            lblInfoPaso.Visible   =  esPaso;
        }

        // -- Evento: CONFIRMAR -----------------------------------------------------
        private void BtnConfirmar_Click(object? sender, EventArgs e)
        {
            if (rdPasoRapido.Checked)
            {
                EspaciosAfectados = 0;
                EsEntrada         = true;
                EsMoto            = false;
                EsPasoRapido      = true;
            }
            else
            {
                EspaciosAfectados = (int)numEspacios.Value;
                EsEntrada         = rdEntrada.Checked;
                EsMoto            = rdMoto.Checked;
                EsPasoRapido      = false;
            }
            DialogResult = DialogResult.OK;
            Close();
        }

        // -- Fábrica de botones redondeados ----------------------------------------
        private static Button CrearBoton(string texto, Rectangle bounds, Color fondo, Color textoColor, Font fuente)
        {
            var btn = new Button
            {
                Text      = texto,
                Font      = fuente,
                ForeColor = textoColor,
                BackColor = fondo,
                FlatStyle = FlatStyle.Flat,
                Bounds    = bounds,
                Cursor    = Cursors.Hand,
                TextAlign = ContentAlignment.MiddleCenter
            };
            btn.FlatAppearance.BorderSize         = 0;
            btn.FlatAppearance.MouseOverBackColor = ControlPaint.Light(fondo, 0.15f);
            btn.FlatAppearance.MouseDownBackColor = ControlPaint.Dark(fondo, 0.1f);
            btn.Paint += (s, e) =>
            {
                var b = (Button)s!;
                using var path  = ConstruirPath(b.ClientRectangle, 10);
                e.Graphics.SmoothingMode = SmoothingMode.AntiAlias;
                using var brush = new SolidBrush(b.BackColor);
                e.Graphics.FillPath(brush, path);
                using var sf    = new StringFormat { Alignment = StringAlignment.Center, LineAlignment = StringAlignment.Center };
                using var tf    = new SolidBrush(b.ForeColor);
                e.Graphics.DrawString(b.Text, b.Font, tf, b.ClientRectangle, sf);
            };
            btn.Region = new Region(ConstruirPath(new Rectangle(0, 0, bounds.Width, bounds.Height), 10));
            return btn;
        }

        // -- Dibujo: borde redondeado del formulario -------------------------------
        private void Form_Paint(object? sender, PaintEventArgs e)
        {
            e.Graphics.SmoothingMode = SmoothingMode.AntiAlias;
            using var pen  = new Pen(Color.FromArgb(200, C_AzulInst), 1.5f);
            using var path = ConstruirPath(new Rectangle(0, 0, Width - 1, Height - 1), 16);
            e.Graphics.DrawPath(pen, path);
        }

        private void AplicarRegionRedondeada()
        {
            Region = new Region(ConstruirPath(new Rectangle(0, 0, Width, Height), 16));
        }

        private static GraphicsPath ConstruirPath(Rectangle rect, int radio)
        {
            var path = new GraphicsPath();
            int d = radio * 2;
            path.AddArc(rect.X,         rect.Y,          d, d, 180, 90);
            path.AddArc(rect.Right - d, rect.Y,          d, d, 270, 90);
            path.AddArc(rect.Right - d, rect.Bottom - d, d, d,   0, 90);
            path.AddArc(rect.X,         rect.Bottom - d, d, d,  90, 90);
            path.CloseFigure();
            return path;
        }
